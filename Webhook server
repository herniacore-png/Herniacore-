const express = require(‘express’);
const app = express();
app.use(express.json());

// ── Your Anthropic API Key ───────────────────────────────
// Set this as an environment variable: ANTHROPIC_API_KEY
const ANTHROPIC_API_KEY = process.env.ANTHROPIC_API_KEY;

// ── In-memory conversation store ─────────────────────────
// For production, replace with Redis or a database
const conversations = {};

// ── HerniaCore System Prompt ──────────────────────────────
const SYSTEM_PROMPT = `You are the official AI assistant for HerniaCore (هيرنيا كور), a surgical clinic in Egypt run by a consultant surgeon specializing in:

PROCEDURES & PRICES:

- Laparoscopic hernia repair: starting from 40,000 EGP
- Simple hernia surgery: starting from 20,000 EGP
